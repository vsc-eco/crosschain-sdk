{
	"name": "@vsc.eco/crosschain-widget",
	"version": "0.0.2",
	"publishConfig": {
		"access": "public"
	},
	"description": "Embeddable Magi QuickSwap widget — React component + web component",
	"keywords": [
		"hive",
		"hbd",
		"bitcoin",
		"vsc",
		"swap",
		"widget",
		"react",
		"web-component",
		"cross-chain"
	],
	"homepage": "https://github.com/vsc-eco/crosschain-sdk/tree/main/packages/widget#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/vsc-eco/crosschain-sdk.git",
		"directory": "packages/widget"
	},
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./webcomponent": {
			"import": "./dist/webcomponent.js"
		},
		"./styles.css": "./dist/styles.css",
		"./themes/altera-dark.css": "./dist/themes/altera-dark.css"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup src/index.tsx src/webcomponent.tsx --format esm --dts --clean --external react --external react-dom --loader .css=copy --loader .svg=dataurl && cp dist/styles-*.css dist/styles.css && mkdir -p dist/themes && cp src/themes/altera-dark.css dist/themes/altera-dark.css",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0",
		"@aioha/aioha": "^1.8.0"
	},
	"peerDependenciesMeta": {
		"@aioha/aioha": {
			"optional": true
		}
	},
	"dependencies": {
		"@vsc.eco/crosschain-core": "0.0.2",
		"@vsc.eco/crosschain-sdk": "0.0.2",
		"bitcoin-address-validation": "^2.2.3",
		"@r2wc/react-to-web-component": "^2.0.3"
	},
	"devDependencies": {
		"@aioha/aioha": "^1.8.2",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"typescript": "^5.7.3",
		"tsup": "^8.3.5",
		"vitest": "^2.1.8"
	}
}
