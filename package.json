{
  "name": "magi-sdk-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "test": "pnpm -r --filter './packages/*' run test",
    "typecheck": "pnpm -r --filter './packages/*' run typecheck",
    "demo": "pnpm --filter demo run dev"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "overrides": {
      "@vsc.eco/crosschain-core": "workspace:*",
      "@vsc.eco/crosschain-sdk": "workspace:*",
      "@vsc.eco/crosschain-widget": "workspace:*"
    }
  },
  "packageManager": "pnpm@10.33.2"
}
